# Function that checks if a year is a leap year
def is_year_leap(year):

    # If the year is divisible by 400, it is a leap year
    if year % 400 == 0:
        return True

    # If the year is divisible by 100 (but not by 400), it is not a leap year
    elif year % 100 == 0:
        return False

    # If the year is divisible by 4, it is a leap year
    elif year % 4 == 0:
        return True

    # Otherwise, it is not a leap year
    else:
        return False


# List containing the number of days in each month
days = [31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31]


# Function that returns the number of days in a given month and year
def days_in_month(year, month):

    # Check if the year or month is invalid
    if year < 1 or month < 1 or month > 12:
        return None

    # Handle February separately because it depends on leap years
    elif month == 2:

        # Return 29 days if it is a leap year
        if is_year_leap(year):
            return 29

        # Otherwise, return 28 days
        else:
            return 28

    # Return the number of days for all other months
    else:
        return days[month - 1]
    


    #

def day_of_year(year, month, day):
    if year < 1 or month < 1 or month > 12:
        return None
    elif day < 1:
        return None
    
    max_days = days_in_month(year, month)

    if day < 1 or day > max_days:
        return None
    
    
    total = 0

    for i in range(month-1):
        total += days_in_month(year, i + 1)

    total += day

    return total






